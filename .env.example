POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=5433

# API
API_HOST_PORT=5050
ASPNETCORE_ENVIRONMENT=Development
ALLOWED_HOSTS=localhost;127.0.0.1;api;web
CORS_ORIGIN=http://localhost:5173

# JWT (REQUIRED — must be at least 32 characters)
JWT_SIGNING_KEY=UgpF87Hm82fECMfMr15Q4hjSC9GOgfCrLuA7Bd9fGrMaXfdMiNDcydug2vqMP
JWT_ISSUER=FinanceTracker
JWT_AUDIENCE=FinanceTracker.Clients
