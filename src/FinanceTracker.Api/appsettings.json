{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=financetracker"
  },
  "Jwt": {
    "Issuer": "FinanceTracker",
    "Audience": "FinanceTracker.Clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "Cors": {
    "Origins": [ "http://localhost:5173" ]
  },
  "Fx": {
    "Refresh": {
      "Enabled": true,
      "BaseUrl": "https://api.nbrb.by/",
      "Interval": "1.00:00:00",
      "InitialDelay": "00:00:30",
      "HttpTimeout": "00:00:10"
    }
  }
}
